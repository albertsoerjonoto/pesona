# Pesona — local environment
# Copy this to .env.local and fill in real values.
# Never commit .env.local; it's gitignored.
# See docs/infra.md for where to get each key.

# ─── Supabase (auth, DB, storage, RLS) ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── AI (coach chat, vision analysis, routine, weekly report) ──────────────
GEMINI_API_KEY=

# ─── Payments (Midtrans) ───────────────────────────────────────────────────
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
# Set to "true" for Midtrans production; omit for sandbox.
MIDTRANS_IS_PRODUCTION=false

# ─── Analytics (PostHog) ───────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
# EU instance for SEA data residency, or omit for us.i.posthog.com default.
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# ─── Error monitoring (Sentry) ─────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Only needed for CI source-map uploads; leave blank locally.
SENTRY_AUTH_TOKEN=

# ─── WhatsApp (Wati) — reminders only, per Meta TOS + spec §5.2 ────────────
WATI_API_KEY=
WATI_API_URL=

# ─── Admin + Cron secrets ──────────────────────────────────────────────────
# Required to access /admin metrics dashboard.
ADMIN_SECRET=
# Required on Authorization: Bearer for every /api/cron/* route.
CRON_SECRET=

# ─── App ───────────────────────────────────────────────────────────────────
# Used for Midtrans redirect URLs and referral share links.
NEXT_PUBLIC_APP_URL=http://localhost:3003
